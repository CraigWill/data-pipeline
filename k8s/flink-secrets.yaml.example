apiVersion: v1
kind: Secret
metadata:
  name: flink-secrets
  namespace: flink
type: Opaque
stringData:
  database-host: "oracle-host"
  database-port: "1521"
  database-username: "finance_user"
  database-password: "your-password-here"
  database-sid: "helowin"
  database-schema: "finance_user"
  jwt-secret: "your-jwt-secret-here-min-32-chars"
  aes-encryption-key: "your-aes-key-here-16-chars"
